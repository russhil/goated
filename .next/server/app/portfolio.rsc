2:T847,{"@context":"https://schema.org","@type":"CollectionPage","name":"GOATED. Portfolio | Software & AI Case Studies","description":"Custom software and AI automation case studies by GOATED.","url":"https://goatedd.tech/portfolio","hasPart":[{"@type":"CreativeWork","name":"Azadi Records","description":"We took 100+ spreadsheets across artists, royalties, splits and ISRC codes and collapsed them into one unified catalogue system. Now expanding to all labels on the roster including Seedhe Maut, with an artist-facing app in development.","creator":{"@type":"Organization","name":"GOATED."}},{"@type":"CreativeWork","name":"Movement by Design","description":"A custom booking and patient management system for a physiotherapy clinic in South Bombay. Replaces phone bookings and paper files entirely.","creator":{"@type":"Organization","name":"GOATED."},"url":"https://movementbydesign.in"},{"@type":"CreativeWork","name":"PSY CRM","description":"A bespoke CRM for a tattoo studio - manages client consultations, artist assignments, design references, and deposit collection in one system.","creator":{"@type":"Organization","name":"GOATED."}},{"@type":"CreativeWork","name":"Parchi AI","description":"Parchi is a tool that automates clinic operations across India - appointments, records, billing, and patient communication in one place.","creator":{"@type":"Organization","name":"GOATED."},"url":"https://www.parchi.tech"},{"@type":"CreativeWork","name":"PSY Website + Shop","description":"A full brand website and e-commerce storefront - merch ordering, artist portfolios, appointment booking, and a backend order management CRM.","creator":{"@type":"Organization","name":"GOATED."},"url":"https://psy-website-kappa.vercel.app/studio"},{"@type":"CreativeWork","name":"Wear World Peace","description":"Built the full e-commerce infrastructure for Wear World Peace - the clothing brand founded by NBA player Ron Artest (Metta World Peace). A complete online store with shipping, operations, orde