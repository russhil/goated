g-relaxed ml-5 mb-2 list-disc","children":[["$","span","0",{"children":""}],["$","strong","1",{"className":"font-semibold text-dark","children":"Compliance overhead:"}],["$","span","2",{"children":" 20-30% of development time"}]]}],["$","li","61",{"className":"font-sans text-base text-gray-600 leading-relaxed ml-5 mb-2 list-disc","children":[["$","span","0",{"children":""}],["$","strong","1",{"className":"font-semibold text-dark","children":"Security testing:"}],["$","span","2",{"children":" 15-20% of development time"}]]}],["$","li","62",{"className":"font-sans text-base text-gray-600 leading-relaxed ml-5 mb-2 list-disc","children":[["$","span","0",{"children":""}],["$","strong","1",{"className":"font-semibold text-dark","children":"Data integrity testing:"}],["$","span","2",{"children":" 10-15% of development time"}]]}],["$","li","63",{"className":"font-sans text-base text-gray-600 leading-relaxed ml-5 mb-2 list-disc","children":[["$","span","0",{"children":""}],["$","strong","1",{"className":"font-semibold text-dark","children":"Infrastructure and operations:"}],["$","span","2",{"children":" 10-15% more complex than standard apps"}]]}],["$","p","64",{"className":"font-sans text-base text-gray-600 leading-relaxed mb-4","children":[["$","span","0",{"children":"For a $50,000 project elsewhere, fintech costs $100,000 to $150,000. But the product is also 10x more valuable because it can actually exist legally and reliably."}]]}],["$","h2","65",{"className":"font-serif text-2xl text-dark mt-12 mb-4","children":"Red Flags When Hiring Fintech Developers"}],["$","li","66",{"className":"font-sans text-base text-gray-600 leading-relaxed ml-5 mb-2 list-disc","children":[["$","span","0",{"children":"Agencies that have never dealt with compliance"}]]}],["$","li","67",{"className":"font-sans text-base text-gray-600 leading-relaxed ml-5 mb-2 list-disc","children":[["$","span","0",{"children":"Teams that treat security as an afterthought"}]]}],["$","li","68",{"className":"font-sa